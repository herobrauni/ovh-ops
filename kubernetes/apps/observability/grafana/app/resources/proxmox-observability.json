{
    "__inputs": [
        {
            "name": "DS_PROMETHEUS",
            "label": "prometheus",
            "type": "datasource",
            "pluginId": "prometheus",
            "pluginName": "Prometheus"
        }
    ],
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 0,
    "panels": [
        {
            "datasource": "${DS_PROMETHEUS}",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "lineWidth": 1,
                        "showPoints": "never"
                    },
                    "unit": "percentunit"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{job=\"proxmox-node-exporter\", mode=\"idle\", role=\"proxmox\", site=~\"$site\", instance=~\"$node\"}[5m])))",
                    "legendFormat": "{{instance}}",
                    "refId": "A"
                }
            ],
            "title": "Host CPU Utilization",
            "type": "timeseries"
        },
        {
            "datasource": "${DS_PROMETHEUS}",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "lineWidth": 1,
                        "showPoints": "never"
                    },
                    "unit": "percentunit"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 0
            },
            "id": 2,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"proxmox-node-exporter\", role=\"proxmox\", site=~\"$site\", instance=~\"$node\"} / node_memory_MemTotal_bytes{job=\"proxmox-node-exporter\", role=\"proxmox\", site=~\"$site\", instance=~\"$node\"}))",
                    "legendFormat": "{{instance}}",
                    "refId": "A"
                }
            ],
            "title": "Host Memory Utilization",
            "type": "timeseries"
        },
        {
            "datasource": "${DS_PROMETHEUS}",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    }
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 8
            },
            "id": 3,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "single"
                }
            },
            "targets": [
                {
                    "expr": "sum by (status) (proxmox_vm_status_running{instance=~\"$pve_api\"})",
                    "legendFormat": "{{status}}",
                    "refId": "A"
                }
            ],
            "title": "VM State Counts",
            "type": "piechart"
        },
        {
            "datasource": "${DS_PROMETHEUS}",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    }
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 8
            },
            "id": 4,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "single"
                }
            },
            "targets": [
                {
                    "expr": "sum by (status) (proxmox_lxc_status_running{instance=~\"$pve_api\"})",
                    "legendFormat": "{{status}}",
                    "refId": "A"
                }
            ],
            "title": "LXC State Counts",
            "type": "piechart"
        },
        {
            "datasource": "${DS_PROMETHEUS}",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green"
                            },
                            {
                                "color": "orange",
                                "value": 1
                            },
                            {
                                "color": "red",
                                "value": 2
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 16,
                "y": 8
            },
            "id": 5,
            "options": {
                "colorMode": "value",
                "graphMode": "none",
                "justifyMode": "auto",
                "orientation": "auto",
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "",
                    "values": false
                },
                "textMode": "auto"
            },
            "targets": [
                {
                    "expr": "sum(max by (instance, pool) (zfs_pool_state{state=~\"DEGRADED|FAULTED|OFFLINE|UNAVAIL|REMOVED|SUSPENDED\", role=\"proxmox\", site=~\"$site\", instance=~\"$node\"}))",
                    "refId": "A"
                }
            ],
            "title": "Storage Pools Unhealthy",
            "type": "stat"
        },
        {
            "datasource": "${DS_PROMETHEUS}",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "lineWidth": 1,
                        "showPoints": "never"
                    },
                    "unit": "percentunit"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 16
            },
            "id": 6,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "expr": "1 - (zfs_pool_free_bytes{role=\"proxmox\", site=~\"$site\", instance=~\"$node\"} / zfs_pool_size_bytes{role=\"proxmox\", site=~\"$site\", instance=~\"$node\"})",
                    "legendFormat": "{{instance}}/{{pool}}",
                    "refId": "A"
                }
            ],
            "title": "ZFS Pool Used Ratio",
            "type": "timeseries"
        },
        {
            "datasource": "${DS_PROMETHEUS}",
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "lineWidth": 1,
                        "showPoints": "always"
                    }
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 16
            },
            "id": 7,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "expr": "up{job=~\"proxmox-exporter|proxmox-node-exporter|proxmox-storage-exporters\", role=~\"proxmox|\"}",
                    "legendFormat": "{{job}} {{instance}}",
                    "refId": "A"
                }
            ],
            "title": "Exporter Health (up)",
            "type": "timeseries"
        }
    ],
    "refresh": "30s",
    "schemaVersion": 39,
    "style": "dark",
    "tags": [
        "proxmox",
        "observability"
    ],
