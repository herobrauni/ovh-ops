{
    "__inputs": [
        {
            "name": "DS_VICTORIALOGS",
            "label": "victoria-logs",
            "type": "datasource",
            "pluginId": "victoriametrics-logs-datasource",
            "pluginName": "VictoriaLogs"
        }
    ],
    "editable": true,
    "graphTooltip": 0,
    "panels": [
        {
            "datasource": "${DS_VICTORIALOGS}",
            "gridPos": {
                "h": 18,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 1,
            "options": {
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": false,
                "showCommonLabels": false,
                "showLabels": true,
                "showTime": true,
                "sortOrder": "Descending",
                "wrapLogMessage": true
            },
            "targets": [
                {
                    "datasource": {
                        "type": "victoriametrics-logs-datasource",
                        "uid": "${DS_VICTORIALOGS}"
                    },
                    "expr": "kubernetes_host=~\"pve.*\" OR kubernetes_node_name=~\"pve.*\"",
                    "queryType": "stats",
                    "refId": "A"
                }
            ],
            "title": "Proxmox-related Logs",
            "type": "logs"
        }
    ],
    "refresh": "30s",
    "schemaVersion": 39,
    "style": "dark",
    "tags": [
        "proxmox",
        "logs"
    ],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-1h",
        "to": "now"
    },
    "title": "Observability / Proxmox / Logs",
    "uid": "proxmox-logs",
    "version": 1
}